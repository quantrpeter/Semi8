# IceSugar 40 (iCE40UP5K-SG48) pin constraints for Open8 soft core demo
#
# Pin numbers follow the proven working reference:
#   icesugar40-example/src/common/io.pcf
#
# Onboard RGB LED: driven as ORDINARY user IO, active-low (drive 0 = LED on),
# exactly like the working leds.v example. No SB_RGBA_DRV hard IP is used.
#
# Clock: 12 MHz oscillator on pin 35 (standard iCESugar clock pin).

# --- Clock input (12 MHz) ---
set_io clk 35

# --- Onboard RGB LED (active-low, same pins as the working example) ---
set_io LED_R 40
set_io LED_G 41
set_io LED_B 39

# --- 8 optional LED outputs on PMOD2 (P2_1..P2_12 in the reference io.pcf) ---
# For an external PMOD LED board or discrete LEDs. Active-low drive from top.v.
set_io led0 46
set_io led1 44
set_io led2 42
set_io led3 37
set_io led4 36
set_io led5 38
set_io led6 43
set_io led7 45

# --- SPI master (iCESugar dedicated SPI header, same pins as reference io.pcf) ---
#   SPI_SS=16  SPI_SCK=15  SPI_MOSI=17  SPI_MISO=14
set_io spi_cs_n 16
set_io spi_sck  15
set_io spi_mosi 17
set_io spi_miso 14
